# PostgreSQL connection string (local or Neon)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/strideos

# Session cookie signing secret (min 32 chars)
SESSION_SECRET=replace-me-with-a-long-random-string

# Optional bootstrap admin (used by db:seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin

# OpenAI-compatible AI provider (insights summaries)
# Production: set these in Vercel → Project → Settings → Environment Variables
AI_BASE_URL=https://apihub.agnes-ai.com/v1
AI_API_KEY=
AI_MODEL=agnes-2.0-flash

# Optional strength template override (JSON array). Leave empty to use defaults.
# STRENGTH_TEMPLATES_JSON=[{"id":"core","name":"Core","description":"...","durationMin":15}]

